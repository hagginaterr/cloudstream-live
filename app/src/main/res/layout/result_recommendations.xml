<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/result_recommendations_filter_button"
            style="@style/BlackButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginStart="0dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="10dp"
            android:text="GogoAnime" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="Past Broadcasts"
            android:textColor="?attr/textColor"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/result_past_broadcasts_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:text="No past broadcasts available."
            android:textColor="?attr/textColor"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.lagradost.cloudstream3.ui.AutofitRecyclerView
            android:id="@+id/result_recommendations_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/primaryBlackBackground"
            android:clipToPadding="false"
            android:descendantFocusability="afterDescendants"
            android:orientation="horizontal"
            app:spanCount="3"
            tools:listitem="@layout/search_result_grid" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="Clips"
            android:textColor="?attr/textColor"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/result_clips_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:text="No clips available."
            android:textColor="?attr/textColor"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.lagradost.cloudstream3.ui.AutofitRecyclerView
            android:id="@+id/result_clips_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/primaryBlackBackground"
            android:clipToPadding="false"
            android:descendantFocusability="afterDescendants"
            android:orientation="horizontal"
            app:spanCount="3"
            tools:listitem="@layout/search_result_grid" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="Highlights"
            android:textColor="?attr/textColor"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/result_highlights_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="8dp"
            android:text="No highlights available."
            android:textColor="?attr/textColor"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.lagradost.cloudstream3.ui.AutofitRecyclerView
            android:id="@+id/result_highlights_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/primaryBlackBackground"
            android:clipToPadding="false"
            android:descendantFocusability="afterDescendants"
            android:orientation="horizontal"
            app:spanCount="3"
            tools:listitem="@layout/search_result_grid" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>